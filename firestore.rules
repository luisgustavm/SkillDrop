    match /rooms/{roomId} {
      allow get: if signedIn();
      allow list: if signedIn() && request.auth.uid in resource.data.memberIds;
      allow create: if owns(request.resource.data.ownerId)
        && request.resource.data.code == roomId
        && request.resource.data.memberIds.size() == 1
        && request.resource.data.memberIds[0] == request.auth.uid
        && isValidRoom(request.resource.data);
      allow update: if isValidRoom(request.resource.data) && (isJoiningRoom() || isMemberRoomUpdate());
      allow delete: if owns(resource.data.ownerId);

      match /messages/{messageId} {
        allow read: if isRoomMember(roomId);
        allow create: if isRoomMember(roomId) && isValidRoomMessage(request.resource.data);
        allow update, delete: if false;
      }
    }

