rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }

    function owns(userId) {
      return signedIn() && request.auth.uid == userId;
    }

    function isSharedUpload() {
      return resource.data.visibility == "shared";
    }

    function isValidRoomId(roomId) {
      return roomId is string && roomId.size() == 8;
    }

    function canReadRoom(roomId) {
      return isValidRoomId(roomId) && isRoomMember(roomId);
    }

    function canReadUpload(uploadId) {
      return signedIn()
        && (
          get(/databases/$(database)/documents/uploads/$(uploadId)).data.userId == request.auth.uid
          || get(/databases/$(database)/documents/uploads/$(uploadId)).data.visibility == "shared"
          || canReadRoom(get(/databases/$(database)/documents/uploads/$(uploadId)).data.roomId)
        );
    }

    function isCodeLanguage(language) {
      return language in ["javascript", "typescript", "python", "java", "csharp", "html", "css", "sql"];
    }

    function isValidCodeSnippet(data) {
      return data.keys().hasOnly([
          "userId", "roomId", "authorName", "authorAvatar", "title", "language", "extension", "code", "createdAt", "updatedAt"
        ])
        && isValidRoomId(data.roomId)
        && data.authorName is string
        && data.authorName.size() > 0
        && data.authorName.size() <= 80
        && (data.authorAvatar == null || data.authorAvatar is string)
        && data.title is string
        && data.title.size() > 0
        && data.title.size() <= 120
        && isCodeLanguage(data.language)
        && data.extension is string
        && data.extension.size() > 0
        && data.extension.size() <= 12
        && data.code is string
        && data.code.size() > 0
        && data.code.size() <= 50000;
    }

    function isValidGlobalAttachment(attachment) {
      return attachment == null || (
        attachment is map
        && attachment.keys().hasOnly(["name", "mimeType", "size", "dataUrl", "kind"])
        && attachment.name is string
        && attachment.name.size() > 0
        && attachment.name.size() <= 120
        && attachment.mimeType is string
        && attachment.mimeType.size() > 0
        && attachment.mimeType.size() <= 120
        && attachment.size is int
        && attachment.size > 0
        && attachment.size <= 512 * 1024
        && attachment.dataUrl is string
        && attachment.dataUrl.size() > 0
        && attachment.dataUrl.size() <= 760000
        && attachment.kind in ["image", "file"]
      );
    }

    function isValidRoom(data) {
      return data.keys().hasOnly([
          "code", "name", "ownerId", "ownerName", "memberIds", "memberCount",
          "pendingRequests", "pendingRequestUserIds",
          "lastMessageText", "lastMessageAuthorName", "lastMessageAt", "createdAt", "updatedAt"
        ])
        && data.code is string
        && data.code.size() == 8
        && data.name is string
        && data.name.size() > 0
        && data.name.size() <= 80
        && data.ownerId is string
        && data.ownerName is string
        && data.ownerName.size() > 0
        && data.ownerName.size() <= 80
        && data.memberIds is list
        && data.memberCount is int
        && data.memberCount >= 1
        && data.pendingRequests is list
        && data.pendingRequestUserIds is list
        && data.lastMessageText is string
        && data.lastMessageText.size() <= 1000
        && data.lastMessageAuthorName is string
        && data.lastMessageAuthorName.size() <= 80;
    }

    function isRoomMember(roomId) {
      return signedIn()
        && isValidRoomId(roomId)
        && request.auth.uid in get(/databases/$(database)/documents/rooms/$(roomId)).data.memberIds;
    }

    function isValidUpload(data) {
      return data.keys().hasOnly([
          "userId", "roomId", "title", "description", "fileUrl", "storagePath", "storageProvider", "localFileId",
          "fileName", "fileType", "mimeType", "size", "tags", "visibility", "shareId", "createdAt", "updatedAt"
        ])
        && owns(data.userId)
        && isValidRoomId(data.roomId)
        && isRoomMember(data.roomId)
        && data.title is string
        && data.title.size() > 0
        && data.title.size() <= 120
        && data.description is string
        && data.description.size() <= 1000
        && data.fileUrl is string
        && data.storagePath is string
        && data.storageProvider in ["browser", "url", "firebase"]
        && (data.localFileId == null || data.localFileId is string)
        && data.fileName is string
        && data.fileType in [
          "pdf", "document", "archive", "image", "video", "text", "code", "link", "other"
        ]
        && data.mimeType is string
        && data.size is int
        && data.size <= 100 * 1024 * 1024
        && data.tags is list
        && data.visibility in ["private", "shared"]
        && data.shareId is string
        && data.shareId.size() > 0;
    }

    function isRequestingRoomAccess() {
      return signedIn()
        && !(request.auth.uid in resource.data.memberIds)
        && !(request.auth.uid in resource.data.pendingRequestUserIds)
        && request.auth.uid in request.resource.data.pendingRequestUserIds
        && request.resource.data.pendingRequestUserIds.size() == resource.data.pendingRequestUserIds.size() + 1
        && request.resource.data.memberIds == resource.data.memberIds
        && request.resource.data.memberCount == resource.data.memberCount
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly([
          "pendingRequests", "pendingRequestUserIds", "updatedAt"
        ]);
    }

    function isOwnerRoomUpdate() {
      return owns(resource.data.ownerId)
        && request.resource.data.code == resource.data.code
        && request.resource.data.ownerId == resource.data.ownerId
        && request.resource.data.createdAt == resource.data.createdAt
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly([
          "name", "pendingRequests", "pendingRequestUserIds", "memberIds", "memberCount", "updatedAt"
        ]);
    }

    function isMemberRoomUpdate() {
      return signedIn()
        && request.auth.uid in resource.data.memberIds
        && request.resource.data.code == resource.data.code
        && request.resource.data.ownerId == resource.data.ownerId
        && request.resource.data.createdAt == resource.data.createdAt
        && request.resource.data.memberIds == resource.data.memberIds
        && request.resource.data.memberCount == resource.data.memberCount
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly([
          "name", "lastMessageText", "lastMessageAuthorName", "lastMessageAt", "updatedAt"
        ]);
    }

    function isValidRoomMessage(data) {
      return data.keys().hasOnly(["userId", "authorName", "authorAvatar", "content", "attachment", "createdAt"])
        && data.userId == request.auth.uid
        && data.authorName is string
        && data.authorName.size() > 0
        && data.authorName.size() <= 80
        && (data.authorAvatar == null || data.authorAvatar is string)
        && data.content is string
        && data.content.size() <= 1000
        && (data.content.size() > 0 || data.attachment != null)
        && isValidGlobalAttachment(data.attachment);
    }

    match /users/{userId} {
      allow read, create, update: if owns(userId);
      allow delete: if false;
    }

    match /uploads/{uploadId} {
      allow read: if owns(resource.data.userId) || isSharedUpload() || canReadRoom(resource.data.roomId);
      allow create: if isValidUpload(request.resource.data);
      allow update, delete: if owns(resource.data.userId);
    }

    match /favorites/{favoriteId} {
      allow read, update, delete: if owns(resource.data.userId);
      allow create: if owns(request.resource.data.userId);
    }

    match /comments/{commentId} {
      allow read: if canReadUpload(resource.data.uploadId);
      allow create: if owns(request.resource.data.userId) && canReadUpload(request.resource.data.uploadId);
      allow update, delete: if owns(resource.data.userId);
    }

    match /chats/{messageId} {
      allow read: if owns(resource.data.userId) && canReadRoom(resource.data.roomId);
      allow create: if owns(request.resource.data.userId) && canReadRoom(request.resource.data.roomId);
      allow update, delete: if false;
    }

    match /globalMessages/{messageId} {
      allow read: if signedIn();
      allow create: if owns(request.resource.data.userId)
        && request.resource.data.keys().hasOnly(["userId", "authorName", "authorAvatar", "content", "attachment", "createdAt"])
        && request.resource.data.authorName is string
        && request.resource.data.authorName.size() > 0
        && request.resource.data.authorName.size() <= 80
        && (request.resource.data.authorAvatar == null || request.resource.data.authorAvatar is string)
        && request.resource.data.content is string
        && request.resource.data.content.size() <= 1000
        && (request.resource.data.content.size() > 0 || request.resource.data.attachment != null)
        && isValidGlobalAttachment(request.resource.data.attachment);
      allow update, delete: if owns(resource.data.userId);
    }

    match /rooms/{roomId} {
      allow get: if signedIn();
      allow list: if signedIn() && request.auth.uid in resource.data.memberIds;
      allow create: if owns(request.resource.data.ownerId)
        && request.resource.data.code == roomId
        && request.resource.data.memberIds.size() == 1
        && request.resource.data.memberIds[0] == request.auth.uid
        && isValidRoom(request.resource.data);
      allow update: if isValidRoom(request.resource.data) && (isRequestingRoomAccess() || isOwnerRoomUpdate() || isMemberRoomUpdate());
      allow delete: if owns(resource.data.ownerId);

      match /messages/{messageId} {
        allow read: if isRoomMember(roomId);
        allow create: if isRoomMember(roomId) && isValidRoomMessage(request.resource.data);
        allow update, delete: if false;
      }
    }

    match /codeSnippets/{snippetId} {
      allow read: if canReadRoom(resource.data.roomId);
      allow create: if owns(request.resource.data.userId)
        && canReadRoom(request.resource.data.roomId)
        && isValidCodeSnippet(request.resource.data);
      allow update: if owns(resource.data.userId)
        && request.resource.data.userId == resource.data.userId
        && request.resource.data.roomId == resource.data.roomId
        && request.resource.data.createdAt == resource.data.createdAt
        && canReadRoom(resource.data.roomId)
        && isValidCodeSnippet(request.resource.data);
      allow delete: if owns(resource.data.userId);
    }

    match /activityLogs/{activityId} {
      allow read: if owns(resource.data.userId) || canReadRoom(resource.data.roomId);
      allow create: if owns(request.resource.data.userId);
      allow update, delete: if false;
    }
  }
}
