    match /users/{userId} {
      allow read, create, update: if owns(userId);
      allow delete: if false;
    }

    match /uploads/{uploadId} {
      allow read: if owns(resource.data.userId) || isSharedUpload();
      allow create: if owns(request.resource.data.userId)
        && request.resource.data.title is string
        && request.resource.data.fileUrl is string
        && request.resource.data.fileType in [
          "pdf", "document", "archive", "image", "video", "text", "code", "link", "other"
        ]
        && request.resource.data.visibility in ["private", "shared"]
        && request.resource.data.size <= 100 * 1024 * 1024;
      allow update, delete: if owns(resource.data.userId);
    }

    match /favorites/{favoriteId} {
      allow read, update, delete: if owns(resource.data.userId);
      allow create: if owns(request.resource.data.userId);
    }

    match /comments/{commentId} {
      allow read: if signedIn();
      allow create: if owns(request.resource.data.userId);
      allow update, delete: if owns(resource.data.userId);
    }

    match /chats/{messageId} {
      allow read: if owns(resource.data.userId);
      allow create: if owns(request.resource.data.userId);
      allow update, delete: if false;
    }

    match /globalMessages/{messageId} {
      allow read: if signedIn();
      allow create: if owns(request.resource.data.userId)
        && request.resource.data.keys().hasOnly(["userId", "authorName", "authorAvatar", "content", "attachment", "createdAt"])
        && request.resource.data.authorName is string
        && request.resource.data.authorName.size() > 0
        && request.resource.data.authorName.size() <= 80
        && (request.resource.data.authorAvatar == null || request.resource.data.authorAvatar is string)
        && request.resource.data.content is string
        && request.resource.data.content.size() <= 1000
        && (request.resource.data.content.size() > 0 || request.resource.data.attachment != null)
        && isValidGlobalAttachment(request.resource.data.attachment);
      allow update, delete: if owns(resource.data.userId);
    }

